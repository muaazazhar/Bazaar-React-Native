EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_GOOGLE_AUTH_BASE_URL=http://localhost:3000
EXPO_PUBLIC_GOOGLE_AUTH_START_PATH=/auth/google
EXPO_PUBLIC_ENABLE_GOOGLE_AUTH=true
EXPO_PUBLIC_GOOGLE_APP_CALLBACK_URL=exp://127.0.0.1:8081/--/auth/google/callback

# OAuth / authentication
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Payment provider credentials (set only if you integrate directly on frontend;
# preferred approach is backend-only secret handling).
EXPO_PUBLIC_JAZZCASH_MERCHANT_ID=
EXPO_PUBLIC_JAZZCASH_INTEGRITY_SALT=
EXPO_PUBLIC_EASYPAISA_STORE_ID=
